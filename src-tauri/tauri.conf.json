{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "shelf",
  "version": "0.1.0",
  "identifier": "com.johnathan.shelf",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "shelf",
        "width": 1200,
        "height": 800,
        "minWidth": 760,
        "minHeight": 520,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
